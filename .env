VITE_API_BASE_URL=http://localhost:8000

# SOCKETS (Local):
VITE_REVERB_APP_KEY=ohsansi_key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080

# ⚠️ MUY IMPORTANTE PARA LOCAL:
# Debe ser 'http' para que Laravel Echo use 'ws://' (WebSocket sin encriptación)
# ya que en local no tenemos certificado SSL.
VITE_REVERB_SCHEME=http